# Copy to .env and set real values before exposing this to anyone.
# In production these come from GitHub Actions secrets (see .github/workflows/deploy.yml).

# Signs the identity cookie. Use a long random string, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional. Raises the Google Books metadata quota. The app works without it.
GOOGLE_BOOKS_API_KEY=

# Cloudflare Tunnel token — only needed for production (the `prod` profile).
# Leave blank for local development.
CF_TUNNEL_TOKEN=
